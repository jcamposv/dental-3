---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import HeroSection from "../components/sections/HeroSection.astro";
import ServicesSection from "../components/sections/ServicesSection.astro";
import WelcomeSection from "../components/sections/WelcomeSection.astro";
import EducationSection from "../components/sections/EducationSection.astro";
import TestimonialsSection from "../components/sections/TestimonialsSection.astro";
import FAQSection from "../components/sections/FAQSection";
---

<BaseLayout>
  <Header />
  <main>
    <HeroSection />
    <ServicesSection />
    <WelcomeSection />
    <EducationSection />
    <TestimonialsSection />
    <FAQSection client:load />
  </main>
  <Footer />
</BaseLayout>
