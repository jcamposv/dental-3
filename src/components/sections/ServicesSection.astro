---
import { services, images } from "../../data/site";
---

<section class="py-20 lg:py-28 bg-white" id="servicios">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-xl mx-auto text-center mb-14 lg:mb-20">
      <h2 class="font-serif text-3xl sm:text-4xl lg:text-5xl text-charcoal leading-tight">
        Servicios que ofrezco con 12 años de experiencia
      </h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-12">
      {services.map((service, i) => (
        <article class="group">
          <div class="flex items-start gap-4 mb-4">
            <span class="text-xs font-semibold text-salmon bg-salmon-lighter rounded-full px-2.5 py-1 shrink-0">
              {service.index}
            </span>
            <!-- Service image -->
            <div class="w-full h-32 rounded-2xl overflow-hidden bg-salmon-lighter">
              <img
                src={images.services[i]}
                alt={service.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            </div>
          </div>
          <h3 class="font-serif text-xl text-charcoal mb-2 italic">{service.title}</h3>
          <p class="text-sm text-muted leading-relaxed">{service.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
