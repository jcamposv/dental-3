---
import { testimonials } from "../../data/site";
---

<section class="py-20 lg:py-28 bg-white" id="sobre-mi">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-xl mx-auto text-center mb-14 lg:mb-20">
      <h2 class="font-serif text-3xl sm:text-4xl lg:text-5xl text-charcoal leading-tight italic">
        Palabras felices con sonrisas felices
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {testimonials.map((t) => (
        <article class="bg-cream rounded-3xl p-8 lg:p-10">
          <p class="text-charcoal leading-relaxed mb-8 text-base">
            "{t.review}"
          </p>
          <div class="flex items-center gap-3 pt-5 border-t border-charcoal/10">
            <div class="w-10 h-10 rounded-full bg-salmon-light flex items-center justify-center">
              <span class="text-salmon-dark font-bold text-sm">{t.name.charAt(0)}</span>
            </div>
            <div>
              <span class="block text-sm font-semibold text-charcoal">{t.name}</span>
              <span class="text-xs text-muted">{t.label}</span>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
